OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional — target Google Sheets ID for build_xlsx upload.
# Leave unset to skip upload and keep the local Results/*.xlsx file.
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_ID_ZH=

# --- Service layer (service/*) --------------------------------------------
# All optional. Unset = zero-infra defaults: SQLite DB + inline (synchronous)
# job execution, so `uvicorn service.api:app` runs with nothing else installed.
#
# DATABASE_URL=postgresql+psycopg://evals:evals@localhost:5432/evals
# REDIS_URL=redis://localhost:6379/0
# INLINE_JOBS=1          # force synchronous execution even if Redis is up
# RUN_CONCURRENCY=20     # max in-flight API calls per run
# API_BASE_URL=http://localhost:8000   # dashboard -> API target
#
# API_TOKEN=<random-secret>   # REQUIRED before exposing the API publicly.
#   When set, POST /runs and cancel need `Authorization: Bearer <token>`;
#   unset = open (fine for local dev). Guards against strangers spending your
#   LLM budget via POST /runs.
